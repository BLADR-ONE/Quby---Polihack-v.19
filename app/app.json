{
  "expo": {
    "name": "quby-app",
    "slug": "quby-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "qubyapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.quby.app",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "Am nevoie de Bluetooth pentru a controla robotul Quby."
      }
    },

    "android": {
      "package": "com.quby.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "react-native-ble-manager",
        {
          "neverForLocation": true,
          "bluetoothAlwaysPermission": "Am nevoie de Bluetooth pentru a controla robotul Quby."
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true
    }
  }
}